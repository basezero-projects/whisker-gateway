# --- engine ---
WHISKER_ENGINE_URL=http://127.0.0.1:8765
# Shared HMAC secret between gateway and engine — both must agree. 32+ random bytes.
WHISKER_INTERNAL_SECRET=replace-me-with-32-random-bytes-base64

# --- database (gateway tables live in `gateway` schema) ---
DATABASE_URL=postgresql://whisker:whisker@127.0.0.1:5432/whisker

# --- better-auth ---
BETTER_AUTH_SECRET=replace-me-with-32-random-bytes-base64
BETTER_AUTH_URL=http://localhost:3000

# --- stripe (test keys for dev, live for prod) ---
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# Metered usage Price ID — tier "Pro", per-minute meter
STRIPE_PRICE_ID_USAGE=price_xxxxx
